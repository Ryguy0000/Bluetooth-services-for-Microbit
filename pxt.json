{
    "name": "UUID Changes",
    "version": "0.0.1",
    "description": "Custom BLE Service and Advertiser",
    "dependencies": {
        "core": "*",
        "bluetooth": "*",
        "microphone": "*"
    },
    "files": [
        "main.ts",
        "custom_ble.cpp"
    ],
    "targetVersions": {
        "target": "9.0.5",
        "targetId": "microbit"
    },
    "supportedTargets": [
        "microbit"
    ],
    "preferredEditor": "tsprj",
    "yotta": {
        "config": {
            "DEVICE_BLE": 1,
            "MICROBIT_BLE_ENABLED": 1,
            "microbit-dal": {
                "bluetooth": {
                    "enabled": 1,
                    "open": 1
                }
            }
        }
    }
}
